# graph of 4. Weekend Hourly Trend  
import seaborn as sns
import matplotlib.pyplot as plt

weekend_df = df_clean[df_clean['day'].isin(['Sat', 'Sun'])]

sns.set_theme(style="whitegrid")
plt.figure(figsize=(12, 6))

sns.lineplot(
    data=weekend_df, 
    x="hour_of_day", 
    y="trip_count", 
    hue="usertype", 
    estimator=sum,      
    marker="o",         
    linewidth=2.5,
    errorbar=None
)

plt.xticks(range(0, 24))

plt.title("Weekend Peak Hour", fontsize=14, fontweight='bold', pad=15)
plt.xlabel("Hour of Day (0-23)", fontsize=12)
plt.ylabel("Total Trips", fontsize=12)
plt.legend(title="User Type", loc="upper left")

plt.tight_layout()
plt.show()
