# graph of 2. Daily Average Riding Volume
import seaborn as sns
import matplotlib.pyplot as plt

df_daily_total = df_clean.groupby(['usertype', 'month', 'day'])['trip_count'].sum().reset_index()

day_order = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun']
sns.set_theme(style="whitegrid")
plt.figure(figsize=(10, 6))

sns.barplot(
    data=df_daily_total, 
    x="day", 
    y="trip_count",       
    hue="usertype", 
    order=day_order, 
    estimator='mean',
    errorbar=None     
)


plt.title("Daily Average Riding Volume by Day of Week", fontsize=14, fontweight='bold', pad=15)
plt.xlabel("day", fontsize=12)
plt.ylabel("average trips per day", fontsize=12)
plt.legend(title="usertype")

plt.tight_layout()
plt.show()


